{% comment %}
  Tienda Lisbon — Hero con video de fondo
  Clona la estructura del image-banner (mismas clases .banner*)
  para heredar alturas, posiciones, overlay y estilos oro rosa,
  pero reproduce un video subido a Shopify en bucle, silenciado
  y con autoplay. Imagen de portada como poster / respaldo.
{% endcomment %}

{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #Banner-{{ section.id }}::after {
    opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
  }
  #Banner-{{ section.id }} .banner__media video,
  #Banner-{{ section.id }} .banner__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #Banner-{{ section.id }} .banner__media video {
    position: absolute;
    inset: 0;
  }
  /* Sin video ni imagen: degradado limpio del esquema (estilo "blanco galería"),
     en vez de la ilustración de relleno de Dawn. */
  #Banner-{{ section.id }} .banner__media-gradient {
    position: absolute;
    inset: 0;
  }
{%- endstyle -%}

<div
  id="Banner-{{ section.id }}"
  class="banner banner--content-align-{{ section.settings.desktop_content_alignment }} banner--content-align-mobile-{{ section.settings.mobile_content_alignment }} banner--{{ section.settings.image_height }}{% if section.settings.show_text_box == false %} banner--desktop-transparent{% endif %}{% if section.settings.show_text_below %} banner--mobile-bottom{%- endif -%}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>
  <div class="banner__media media{% if section.settings.video == blank and section.settings.cover_image == blank %} placeholder{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {%- if section.settings.video != blank -%}
      {{
        section.settings.video
        | video_tag:
          image_size: '1100x',
          autoplay: true,
          loop: section.settings.enable_video_looping,
          muted: true,
          controls: false,
          playsinline: true,
          preload: 'auto',
          poster: section.settings.cover_image
      }}
    {%- elsif section.settings.cover_image != blank -%}
      {{
        section.settings.cover_image
        | image_url: width: 3840
        | image_tag:
          width: section.settings.cover_image.width,
          height: section.settings.cover_image.height,
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          fetchpriority: 'high'
      }}
    {%- else -%}
      <div class="banner__media-gradient color-{{ section.settings.color_scheme }} gradient"></div>
    {%- endif -%}
  </div>

  <div class="banner__content banner__content--{{ section.settings.desktop_content_position }} page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <div class="banner__box content-container content-container--full-width-mobile color-{{ section.settings.color_scheme }} gradient">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2
              class="banner__heading inline-richtext {{ block.settings.heading_size }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.heading }}
            </h2>
          {%- when 'text' -%}
            <div class="banner__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
              <p>{{ block.settings.text }}</p>
            </div>
          {%- when 'buttons' -%}
            <div
              class="banner__buttons{% if block.settings.button_label_1 != blank and block.settings.button_label_2 != blank %} banner__buttons--multiple{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.button_label_1 != blank -%}
                <a
                  {% if block.settings.button_link_1 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_1 }}"
                  {% endif %}
                  class="button{% if block.settings.button_style_secondary_1 %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{- block.settings.button_label_1 | escape -}}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a
                  {% if block.settings.button_link_2 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_2 }}"
                  {% endif %}
                  class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{- block.settings.button_label_2 | escape -}}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Banner con video",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video de fondo"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Imagen de portada (poster / respaldo)",
      "info": "Se muestra mientras carga el video y en dispositivos que no lo reproducen."
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "default": true,
      "label": "Reproducir en bucle"
    },
    {
      "type": "range",
      "id": "image_overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Opacidad de la capa oscura",
      "default": 20
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        { "value": "small", "label": "Pequeña" },
        { "value": "medium", "label": "Mediana" },
        { "value": "large", "label": "Grande" }
      ],
      "default": "large",
      "label": "Altura del banner"
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "options": [
        { "value": "top-left", "label": "Arriba izquierda" },
        { "value": "top-center", "label": "Arriba centro" },
        { "value": "top-right", "label": "Arriba derecha" },
        { "value": "middle-left", "label": "Centro izquierda" },
        { "value": "middle-center", "label": "Centro" },
        { "value": "middle-right", "label": "Centro derecha" },
        { "value": "bottom-left", "label": "Abajo izquierda" },
        { "value": "bottom-center", "label": "Abajo centro" },
        { "value": "bottom-right", "label": "Abajo derecha" }
      ],
      "default": "middle-center",
      "label": "Posición del contenido (escritorio)"
    },
    {
      "type": "select",
      "id": "desktop_content_alignment",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "center",
      "label": "Alineación del contenido (escritorio)"
    },
    {
      "type": "checkbox",
      "id": "show_text_box",
      "default": true,
      "label": "Mostrar caja de texto en escritorio"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Combinación de colores",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "Móvil"
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "center",
      "label": "Alineación del contenido (móvil)"
    },
    {
      "type": "checkbox",
      "id": "show_text_below",
      "default": false,
      "label": "Mostrar el contenido debajo del video en móvil"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Titular",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Banner con video",
          "label": "Titular"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            { "value": "h2", "label": "Pequeño" },
            { "value": "h1", "label": "Mediano" },
            { "value": "h0", "label": "Grande" },
            { "value": "hxl", "label": "Extra grande" },
            { "value": "hxxl", "label": "Enorme" }
          ],
          "default": "h1",
          "label": "Tamaño del titular"
        }
      ]
    },
    {
      "type": "text",
      "name": "Texto",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Cuenta tu historia de marca con movimiento.",
          "label": "Texto"
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            { "value": "body", "label": "Cuerpo" },
            { "value": "subtitle", "label": "Subtítulo" },
            { "value": "caption-with-letter-spacing", "label": "Mayúsculas espaciadas" }
          ],
          "default": "body",
          "label": "Estilo del texto"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Botones",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Botón 1" },
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Descubrir",
          "label": "Etiqueta del botón",
          "info": "Deja la etiqueta vacía para ocultar el botón."
        },
        { "type": "url", "id": "button_link_1", "label": "Enlace del botón" },
        {
          "type": "checkbox",
          "id": "button_style_secondary_1",
          "default": false,
          "label": "Usar estilo de botón secundario"
        },
        { "type": "header", "content": "Botón 2" },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Etiqueta del botón",
          "info": "Deja la etiqueta vacía para ocultar el botón."
        },
        { "type": "url", "id": "button_link_2", "label": "Enlace del botón" },
        {
          "type": "checkbox",
          "id": "button_style_secondary_2",
          "default": false,
          "label": "Usar estilo de botón secundario"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner con video",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
