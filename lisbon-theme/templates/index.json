    "ingrediente_skin1004": {
      "type": "image-with-text",
      "blocks": {
        "caption": {
          "type": "caption",
          "settings": {
            "caption": "El ingrediente · Centella Asiática",
            "text_style": "caption-with-letter-spacing",
            "text_size": "medium"
          }
        },
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Centella de Madagascar: calma pura para tu piel",
            "heading_size": "h1"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>SKIN1004 cultiva su centella en Madagascar, lejos de la contaminación, y la trabaja sin agua añadida. El resultado: fórmulas que calman rojeces, reparan la barrera y devuelven la serenidad a la piel más sensible.</p>"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "button_label": "Ver la colección",
            "button_link": "shopify://collections/skincare"
          }
        }
      },
